[Unit]
Description=Haibao Kuaisheng FastAPI Web
After=network.target

[Service]
Type=simple
User=haibao
Group=haibao
WorkingDirectory=/opt/haibaokuaisheng
EnvironmentFile=/etc/haibaokuaisheng/haibaokuaisheng.env
ExecStart=/opt/haibaokuaisheng/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target


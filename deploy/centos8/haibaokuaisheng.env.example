# Copy to /etc/haibaokuaisheng/haibaokuaisheng.env and adjust values.

HAIBAO_SECRET_KEY=replace-with-a-long-random-secret
HAIBAO_DATABASE_URL=sqlite:////opt/haibaokuaisheng/data/app.db
HAIBAO_DATA_DIR=/opt/haibaokuaisheng/data
HAIBAO_UPLOAD_DIR=/opt/haibaokuaisheng/uploads
HAIBAO_TOKEN_TTL_SECONDS=604800
HAIBAO_MAX_UPLOAD_SIZE=10485760

# Worker settings. One worker is enough for the SQLite MVP deployment.
HAIBAO_WORKER_POLL_SECONDS=3
HAIBAO_WORKER_BATCH_SIZE=1
HAIBAO_TASK_STALE_SECONDS=1800


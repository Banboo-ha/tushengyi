.hero {
  padding: 34rpx;
  margin-bottom: 20rpx;
}

.eyebrow {
  color: #6281ff;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin: 8rpx 0 12rpx;
  font-size: 42rpx;
  font-weight: 950;
}

.package {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.package-title {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 950;
}

.package-side {
  text-align: right;
}

.price {
  margin-bottom: 12rpx;
  color: #ff7d2d;
  font-size: 34rpx;
  font-weight: 950;
}

.buy {
  width: 154rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 25rpx;
}

.empty {
  padding: 54rpx 24rpx;
  text-align: center;
  color: #7d8bac;
}

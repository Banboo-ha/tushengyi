<view class="page plaza-page">
  <view class="section-head">
    <view>
      <text class="eyebrow">Popular Works</text>
      <view class="title">热门作品</view>
    </view>
    <text class="muted">按点赞热度排序</text>
  </view>

  <view wx:if="{{loading}}" class="empty card">加载中...</view>
  <view wx:elif="{{!works.length}}" class="empty card">还没有可展示的作品</view>
  <view wx:else class="feed-grid">
    <view
      wx:for="{{works}}"
      wx:key="version_id"
      class="feed-card"
      bindtap="openWork"
      data-item="{{item}}"
    >
      <image src="{{item.cover}}" mode="widthFix" />
      <view class="feed-meta">
        <text class="feed-title">{{item.title || '未命名作品'}}</text>
        <view class="feed-sub">
          <text class="feed-author">{{item.author_name || '图生意用户'}}</text>
          <view class="like" catchtap="like" data-index="{{index}}">
            <text>{{item.liked_by_me ? '♥' : '♡'}}</text>
            <text>{{item.likes_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

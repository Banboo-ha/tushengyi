.plaza-page {
  padding-bottom: 40rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #6281ff;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 4rpx;
  font-size: 42rpx;
  font-weight: 950;
}

.empty {
  padding: 54rpx 24rpx;
  text-align: center;
  color: #7d8bac;
}

.like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  color: #ff5d8b;
  font-weight: 800;
}

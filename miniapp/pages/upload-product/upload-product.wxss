.step { margin: 16rpx 0 26rpx; text-align: center; color: #4560a5; font-weight: 900; }
.guide {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.guide image {
  width: 58rpx;
  height: 58rpx;
  flex-shrink: 0;
}

.guide text:first-child {
  display: block;
  color: #08184f;
  font-size: 27rpx;
  font-weight: 900;
}

.guide text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #7d8bac;
  font-size: 23rpx;
  line-height: 1.35;
}

.upload-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; }
.slot { position: relative; min-height: 260rpx; border-radius: 28rpx; overflow: hidden; background: #eef5ff; }
.slot image { width: 100%; height: 260rpx; }
.slot text:first-of-type { position: absolute; right: 12rpx; top: 12rpx; width: 42rpx; height: 42rpx; border-radius: 50%; background: rgba(8,24,79,.62); color: #fff; text-align: center; line-height: 42rpx; }
.add { display: grid; place-items: center; color: #2d7cff; border: 2rpx dashed #b9cdf8; }
.add text:first-child { position: static; width: auto; height: auto; background: transparent; color: #2d7cff; font-size: 54rpx; }
.bottom { margin-top: 34rpx; }

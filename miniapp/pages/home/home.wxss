.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.logo { width: 178rpx; display: block; }
.slogan { display: block; margin-top: 8rpx; color: #7d8bac; font-size: 24rpx; }
.user { padding: 12rpx 18rpx; border-radius: 999rpx; background: #fff; color: #2d7cff; font-size: 24rpx; }
.hero {
  position: relative;
  min-height: 286rpx;
  margin: 28rpx 0 22rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f3f8ff, #ffffff);
}

.hero-bg {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: .98;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 55%;
  padding: 34rpx;
}

.hero-title { display: block; font-size: 40rpx; font-weight: 950; line-height: 1.18; }
.hero-sub { display: block; margin: 14rpx 0 24rpx; color: #7d8bac; font-size: 25rpx; line-height: 1.45; }
.hero button { width: 206rpx; height: 68rpx; line-height: 68rpx; font-size: 25rpx; }

.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.feature {
  padding: 18rpx 8rpx 16rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(70, 91, 158, .10);
}

.feature image {
  width: 54rpx;
  height: 54rpx;
  display: block;
  margin: 0 auto 10rpx;
}

.feature text:nth-of-type(1) {
  display: block;
  overflow: hidden;
  color: #08184f;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 23rpx;
  font-weight: 900;
}

.feature text:nth-of-type(2) {
  display: block;
  margin-top: 4rpx;
  color: #7d8bac;
  font-size: 20rpx;
}
.section-head { margin: 8rpx 0 20rpx; display: flex; justify-content: space-between; font-weight: 900; }
.section-head text:last-child { color: #2d7cff; font-size: 24rpx; }

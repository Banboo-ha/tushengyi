<view class="page">
  <view class="section-head">
    <view>
      <text class="eyebrow">Library</text>
      <view class="title">我的作品</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty card">加载中...</view>
  <view wx:elif="{{!works.length}}" class="empty card">
    <view>还没有生成作品</view>
    <button class="primary start" bindtap="create">去生成</button>
  </view>
  <view wx:else class="feed-grid">
    <view wx:for="{{works}}" wx:key="version_id" class="feed-card" bindtap="openWork" data-item="{{item}}">
      <image src="{{item.cover}}" mode="widthFix" />
      <view class="feed-meta">
        <text class="feed-title">{{item.title || '未命名作品'}}</text>
        <view class="feed-sub">
          <text class="feed-author">当前 V{{item.version_no}}</text>
          <text>{{item.created_at_text}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

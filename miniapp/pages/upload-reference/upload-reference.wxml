<view class="page">
  <view class="step">2/4 添加参考素材</view>
  <view class="guide card">
    <image src="/assets/ui_v1/common/icon_04_megaphone.png" mode="aspectFit"></image>
    <view>
      <text>参考图可选，最多 4 张</text>
      <text>可以上传背景、氛围、版式或品牌参考。</text>
    </view>
  </view>
  <view class="upload-grid">
    <view class="slot" wx:for="{{images}}" wx:key="image_id">
      <image src="{{item.url}}" mode="aspectFill"></image>
      <text catchtap="remove" data-index="{{index}}">×</text>
    </view>
    <view class="slot add" wx:if="{{images.length < 4}}" bindtap="choose"><text>＋</text><text>上传参考图</text></view>
  </view>
  <view class="actions"><button class="secondary" bindtap="skip">跳过</button><button class="primary" bindtap="skip">下一步</button></view>
</view>

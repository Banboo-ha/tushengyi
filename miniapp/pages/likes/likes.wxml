<view class="page">
  <view class="section-head">
    <view>
      <text class="eyebrow">Liked</text>
      <view class="title">我的喜欢</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty card">加载中...</view>
  <view wx:elif="{{!works.length}}" class="empty card">还没有点赞过作品</view>
  <view wx:else class="feed-grid">
    <view wx:for="{{works}}" wx:key="version_id" class="feed-card" bindtap="openWork" data-item="{{item}}">
      <image src="{{item.cover}}" mode="widthFix" />
      <view class="feed-meta">
        <text class="feed-title">{{item.title || '未命名作品'}}</text>
        <view class="feed-sub">
          <text class="feed-author">{{item.author_name || '图生意用户'}}</text>
          <view class="like">
            <text>♥</text>
            <text>{{item.likes_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

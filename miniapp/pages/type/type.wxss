.title {
  position: relative;
  padding: 28rpx 6rpx 34rpx;
  text-align: center;
}

.title text:first-child {
  display: block;
  font-size: 44rpx;
  font-weight: 950;
  letter-spacing: 0;
}

.title text:last-child {
  display: block;
  margin-top: 12rpx;
  color: #7d8bac;
  font-size: 28rpx;
  font-weight: 700;
}

.type-card {
  position: relative;
  min-height: 220rpx;
  margin-bottom: 22rpx;
  padding: 34rpx 260rpx 30rpx 34rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 18rpx 42rpx rgba(65, 91, 170, .13);
}

.blue { background: linear-gradient(90deg, #ffffff 0%, #f8fbff 48%, #e7f5ff 100%); }
.pink { background: linear-gradient(90deg, #ffffff 0%, #fff7fa 46%, #ffeaf2 100%); }
.orange { background: linear-gradient(90deg, #ffffff 0%, #fffaf2 46%, #fff1db 100%); }
.purple { background: linear-gradient(90deg, #ffffff 0%, #faf7ff 46%, #efe8ff 100%); }

.type-copy {
  position: relative;
  z-index: 2;
}

.icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

.name {
  display: block;
  margin-top: 22rpx;
  color: #08184f;
  font-size: 34rpx;
  font-weight: 950;
}

.desc {
  display: block;
  margin-top: 12rpx;
  color: #667391;
  font-size: 25rpx;
  line-height: 1.45;
}

.visual {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 1;
  height: 100%;
}

.arrow {
  position: absolute;
  right: 42rpx;
  top: 50%;
  z-index: 3;
  width: 62rpx;
  height: 62rpx;
  margin-top: -31rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .92);
  color: #2d7cff;
  text-align: center;
  line-height: 58rpx;
  font-size: 54rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(65, 91, 170, .14);
}
